# ============================================================
# Aura Sense4 — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Google Gemini (backend) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Firebase Admin SDK (backend only — service account) ---
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as-is (including -----BEGIN/END----- lines, with \n for newlines)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# --- Firebase Client SDK (frontend, must be prefixed VITE_) ---
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# --- Backend server ---
PORT=3001
NODE_ENV=development
# Production: set to your Firebase Hosting URL e.g. https://your-project.web.app
FRONTEND_URL=http://localhost:5173

# --- Frontend API URL (build-time env var) ---
# Development: leave empty (Vite proxy handles it)
# Production: set to your Cloud Run URL e.g. https://aura-backend-xxxxxxxx-xx.a.run.app
VITE_API_URL=

# --- Google ADK / Agent Platform (future phases) ---
GOOGLE_ADK_PROJECT_ID=your_gcp_project_id
GOOGLE_ADK_LOCATION=asia-southeast1
